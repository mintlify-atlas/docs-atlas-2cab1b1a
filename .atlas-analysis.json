  "keyFeatures": [
    "Send webhooks with a single API call across 9+ official language SDKs",
    "Automatic retries with configurable retry schedules",
    "Symmetric (HMAC) and asymmetric (Ed25519) webhook signature verification",
    "Self-hostable Rust server with Docker and Kubernetes support",
    "Consumer App Portal for end-users to manage their webhook endpoints",
    "Svix Bridge for integrating with Kafka, RabbitMQ, GCP Pub/Sub, SQS, and Redis",
    "Operational webhooks for server-side event notifications",
    "OpenTelemetry tracing support",
    "CLI tool for local development and webhook testing"
  ],
  "publicApiSurface": [
    "POST /api/v1/app/ — Create application",
    "GET /api/v1/app/ — List applications",
    "POST /api/v1/app/{app_id}/msg/ — Create message",
    "GET /api/v1/app/{app_id}/msg/ — List messages",
    "POST /api/v1/app/{app_id}/endpoint/ — Create endpoint",
    "GET /api/v1/app/{app_id}/endpoint/ — List endpoints",
    "GET /api/v1/app/{app_id}/attempt/msg/{msg_id}/ — List message attempts",
    "POST /api/v1/app/{app_id}/attempt/msg/{msg_id}/{endpoint_id}/resend/ — Resend message",
    "GET /api/v1/event-type/ — List event types",
    "POST /api/v1/auth/app-portal-access/{app_id}/ — Get app portal access token",
    "Webhook.verify() — Verify incoming webhook signature (all SDKs)",
    "Svix(token) — Main SDK client constructor (JS/Python/Go/etc.)"
  ]
}
